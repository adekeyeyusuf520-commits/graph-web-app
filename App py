from flask import Flask, render_template, jsonify

app = Flask(__name__)

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/data')
def data():
    chart_data = {
        "labels": ["Jan", "Feb", "Mar", "Apr"],
        "values": [10, 20, 30, 40]
    }
    return jsonify(chart_data)

if __name__ == '__main__':
    app.run(debug=True)
